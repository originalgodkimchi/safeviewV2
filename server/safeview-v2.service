[Unit]
Description=SAFEVIEW FastAPI Backend
After=network.target mediamtx.service
Wants=mediamtx.service

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/safeviewV2
ExecStart=/home/ubuntu/safeviewV2/venv/bin/uvicorn backend.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
